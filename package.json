{
  "name": "sonictag-ai",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "DATABASE_PATH=/app/database.sqlite npm run create-admin && DATABASE_PATH=/app/database.sqlite npx tsx src/backend/app.ts",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build": "vite build && npm run build:backend",
    "start": "npm run create-admin && node dist/backend/backend/app.js",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "create-admin": "npx tsx src/backend/scripts/createAdmin.ts",
    "migrate-settings": "npx tsx src/backend/scripts/migrateSettings.ts"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "browser-id3-writer": "^6.3.1",
    "clsx": "2.1.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "0.294.0",
    "multer": "^2.0.2",
    "music-metadata": "^11.10.3",
    "node-id3": "^0.2.9",
    "node-shazam": "^1.2.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-jsx-runtime": "^1.0.0-alpha.1",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28"
  },
  "optionalDependencies": {
    "express": "^4.18.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
